<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PaycheckCalc.Avalonia.Views.CreditsView">
  <ScrollViewer>
    <StackPanel Margin="16" Spacing="8">
      <TextBlock Text="Tax Credits" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>
      <TextBlock Text="Configure your tax credits for the annual tax calculation."/>

      <TextBlock Text="Child &amp; Dependent Care Credits" FontWeight="SemiBold" Margin="0,8,0,0"/>
      <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Qualifying Children:" VerticalAlignment="Center"/>
        <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding Session.Credits.QualifyingChildren}" Minimum="0"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Other Dependents:" VerticalAlignment="Center" Margin="0,4,0,0"/>
        <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding Session.Credits.OtherDependents}" Minimum="0" Margin="0,4,0,0"/>
      </Grid>

      <Button Content="Apply" Command="{Binding ApplyCommand}" HorizontalAlignment="Left" Margin="0,12,0,0"/>
    </StackPanel>
  </ScrollViewer>
</UserControl>
