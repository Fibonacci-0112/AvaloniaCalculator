<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PaycheckCalc.Avalonia.ViewModels"
             xmlns:helpers="clr-namespace:PaycheckCalc.Avalonia.Helpers"
             x:Class="PaycheckCalc.Avalonia.Views.JobsAndYtdView"
             x:DataType="vm:JobsAndYtdViewModel">
  <ScrollViewer>
    <StackPanel Margin="16" Spacing="8">
      <TextBlock Text="Jobs &amp; YTD Withholding" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>
      <TextBlock Text="Enter your W-2 jobs and year-to-date withholding information."/>

      <TextBlock Text="W-2 Jobs" FontWeight="SemiBold" Margin="0,8,0,0"/>
      <ItemsControl ItemsSource="{Binding Session.W2Jobs}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="vm:W2JobItemViewModel">
            <Border Padding="8" Margin="0,4" Background="#F8F8F8" CornerRadius="4">
              <StackPanel Spacing="4">
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto">
                  <TextBlock Grid.Column="0" Text="Employer Name:" VerticalAlignment="Center"/>
                  <TextBox Grid.Column="1" Text="{Binding Name}"/>
                </Grid>

                <TextBlock Text="Wages (Box 1 / 3 / 5 / 16)" FontWeight="SemiBold" Margin="0,6,0,0"/>
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Federal Wages (Box 1):" VerticalAlignment="Center"/>
                  <TextBox Grid.Row="0" Grid.Column="1"
                           Text="{Binding WagesBox1, Converter={x:Static helpers:MoneyConverter.Instance}}"
                           helpers:FormattedInput.Mode="Money"/>

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Social Security Wages (Box 3):" VerticalAlignment="Center" Margin="0,4,0,0"/>
                  <TextBox Grid.Row="1" Grid.Column="1"
                           Text="{Binding SocialSecurityWagesBox3, Converter={x:Static helpers:MoneyConverter.Instance}}"
                           helpers:FormattedInput.Mode="Money"
                           Margin="0,4,0,0"/>

                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Medicare Wages (Box 5):" VerticalAlignment="Center" Margin="0,4,0,0"/>
                  <TextBox Grid.Row="2" Grid.Column="1"
                           Text="{Binding MedicareWagesBox5, Converter={x:Static helpers:MoneyConverter.Instance}}"
                           helpers:FormattedInput.Mode="Money"
                           Margin="0,4,0,0"/>

                  <TextBlock Grid.Row="3" Grid.Column="0" Text="State Wages (Box 16):" VerticalAlignment="Center" Margin="0,4,0,0"/>
                  <TextBox Grid.Row="3" Grid.Column="1"
                           Text="{Binding StateWagesBox16, Converter={x:Static helpers:MoneyConverter.Instance}}"
                           helpers:FormattedInput.Mode="Money"
                           Margin="0,4,0,0"/>
                </Grid>

                <TextBlock Text="Withholding (Box 2 / 4 / 6 / 17)" FontWeight="SemiBold" Margin="0,6,0,0"/>
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto">
                  <TextBlock Grid.Row="0" Grid.Column="0" Text="Federal Withholding (Box 2):" VerticalAlignment="Center"/>
                  <TextBox Grid.Row="0" Grid.Column="1"
                           Text="{Binding FederalWithholdingBox2, Converter={x:Static helpers:MoneyConverter.Instance}}"
                           helpers:FormattedInput.Mode="Money"/>

                  <TextBlock Grid.Row="1" Grid.Column="0" Text="Social Security Withholding (Box 4):" VerticalAlignment="Center" Margin="0,4,0,0"/>
                  <TextBox Grid.Row="1" Grid.Column="1"
                           Text="{Binding SocialSecurityTaxBox4, Converter={x:Static helpers:MoneyConverter.Instance}}"
                           helpers:FormattedInput.Mode="Money"
                           Margin="0,4,0,0"/>

                  <TextBlock Grid.Row="2" Grid.Column="0" Text="Medicare Withholding (Box 6):" VerticalAlignment="Center" Margin="0,4,0,0"/>
                  <TextBox Grid.Row="2" Grid.Column="1"
                           Text="{Binding MedicareTaxBox6, Converter={x:Static helpers:MoneyConverter.Instance}}"
                           helpers:FormattedInput.Mode="Money"
                           Margin="0,4,0,0"/>

                  <TextBlock Grid.Row="3" Grid.Column="0" Text="State Withholding (Box 17):" VerticalAlignment="Center" Margin="0,4,0,0"/>
                  <TextBox Grid.Row="3" Grid.Column="1"
                           Text="{Binding StateWithholdingBox17, Converter={x:Static helpers:MoneyConverter.Instance}}"
                           helpers:FormattedInput.Mode="Money"
                           Margin="0,4,0,0"/>
                </Grid>

                <CheckBox Content="Spouse's Job" IsChecked="{Binding IsSpouse}" Margin="0,4,0,0"/>
              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
        <Button Content="Add Job" Command="{Binding AddW2JobCommand}"/>
        <Button Content="Remove Last" Command="{Binding RemoveLastW2JobCommand}"/>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
