<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PaycheckCalc.Avalonia.ViewModels"
             x:Class="PaycheckCalc.Avalonia.Views.JobsAndYtdView"
             x:DataType="vm:JobsAndYtdViewModel">
  <ScrollViewer>
    <StackPanel Margin="16" Spacing="8">
      <TextBlock Text="Jobs &amp; YTD Withholding" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>
      <TextBlock Text="Enter your W-2 jobs and year-to-date withholding information."/>

      <TextBlock Text="W-2 Jobs" FontWeight="SemiBold" Margin="0,8,0,0"/>
      <ItemsControl ItemsSource="{Binding Session.W2Jobs}">
        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="vm:W2JobItemViewModel">
            <Border Padding="8" Margin="0,2" Background="#F8F8F8" CornerRadius="4">
              <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Wages:" VerticalAlignment="Center"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding WagesBox1}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Federal Withholding:" VerticalAlignment="Center" Margin="0,4,0,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FederalWithholdingBox2}" Margin="0,4,0,0"/>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
        <Button Content="Add Job" Command="{Binding AddW2JobCommand}"/>
        <Button Content="Remove Last" Command="{Binding RemoveLastW2JobCommand}"/>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
