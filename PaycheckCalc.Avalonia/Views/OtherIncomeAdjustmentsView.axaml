<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PaycheckCalc.Avalonia.ViewModels"
             xmlns:helpers="clr-namespace:PaycheckCalc.Avalonia.Helpers"
             x:Class="PaycheckCalc.Avalonia.Views.OtherIncomeAdjustmentsView"
             x:DataType="vm:OtherIncomeAdjustmentsViewModel">
  <ScrollViewer>
    <StackPanel Margin="16" Spacing="8">
      <TextBlock Text="Other Income &amp; Adjustments" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>

      <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Other Income:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1"
                 Text="{Binding Session.OtherAdditionalIncome, Converter={x:Static helpers:MoneyConverter.Instance}}"
                 helpers:FormattedInput.Mode="Money"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Taxable Interest:" VerticalAlignment="Center" Margin="0,4,0,0"/>
        <TextBox Grid.Row="1" Grid.Column="1"
                 Text="{Binding Session.TaxableInterest, Converter={x:Static helpers:MoneyConverter.Instance}}"
                 helpers:FormattedInput.Mode="Money"
                 Margin="0,4,0,0"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Itemized Deductions:" VerticalAlignment="Center" Margin="0,4,0,0"/>
        <TextBox Grid.Row="2" Grid.Column="1"
                 Text="{Binding Session.ItemizedDeductionsOverStandard, Converter={x:Static helpers:MoneyConverter.Instance}}"
                 helpers:FormattedInput.Mode="Money"
                 Margin="0,4,0,0"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Student Loan Interest:" VerticalAlignment="Center" Margin="0,4,0,0"/>
        <TextBox Grid.Row="3" Grid.Column="1"
                 Text="{Binding Session.StudentLoanInterest, Converter={x:Static helpers:MoneyConverter.Instance}}"
                 helpers:FormattedInput.Mode="Money"
                 Margin="0,4,0,0"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Traditional IRA Deduction:" VerticalAlignment="Center" Margin="0,4,0,0"/>
        <TextBox Grid.Row="4" Grid.Column="1"
                 Text="{Binding Session.TraditionalIraDeduction, Converter={x:Static helpers:MoneyConverter.Instance}}"
                 helpers:FormattedInput.Mode="Money"
                 Margin="0,4,0,0"/>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
