<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PaycheckCalc.Avalonia.ViewModels"
             x:Class="PaycheckCalc.Avalonia.Views.AnnualTaxView"
             x:DataType="vm:AnnualTaxViewModel">
  <ScrollViewer>
    <StackPanel Margin="16" Spacing="8">
      <TextBlock Text="Annual Tax Calculator" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>
      <TextBlock Text="Configure your annual tax scenario using the Jobs &amp; YTD, Credits, and Other Income pages."/>
      <Button Content="Calculate Annual Tax" Command="{Binding CalculateCommand}" HorizontalAlignment="Stretch"
              Margin="0,12,0,0" Padding="8"/>
      <TextBox Text="{Binding ScenarioNameEntry}" Watermark="Scenario name (optional)"/>
      <Button Content="Save Scenario" Command="{Binding SaveScenarioCommand}" HorizontalAlignment="Left"/>

      <Border IsVisible="{Binding Session.ResultModel, Converter={x:Static ObjectConverters.IsNotNull}}"
              Background="#F0F0F0" CornerRadius="4" Padding="12" Margin="0,8,0,0">
        <StackPanel Spacing="4">
          <TextBlock Text="Annual Tax Results" FontWeight="Bold" FontSize="16"/>
          <TextBlock Text="{Binding Session.ResultModel.AdjustedGrossIncome, StringFormat='AGI: {0:C}'}" />
          <TextBlock Text="{Binding Session.ResultModel.TaxableIncome, StringFormat='Taxable Income: {0:C}'}" />
          <TextBlock Text="{Binding Session.ResultModel.IncomeTaxAfterCredits, StringFormat='Federal Tax: {0:C}'}" />
          <TextBlock Text="{Binding Session.ResultModel.EffectiveTaxRateFormatted, StringFormat='Effective Rate: {0}'}" FontWeight="Bold"/>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
