<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PaycheckCalc.Avalonia.Views.AnnualProjectionView">
  <ScrollViewer>
    <StackPanel Margin="16" Spacing="8">
      <TextBlock Text="Annual Projection" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>
      <TextBlock Text="Annual projection based on current paycheck inputs."/>
      <Button Content="Refresh" Command="{Binding RefreshCommand}" HorizontalAlignment="Left"/>

      <Border IsVisible="{Binding HasProjection}"
              Background="#F0F0F0" CornerRadius="4" Padding="12" Margin="0,8,0,0">
        <StackPanel Spacing="4">
          <TextBlock Text="{Binding Projection.AnnualGrossPay, StringFormat='Annual Gross Pay: {0:C}'}" />
          <TextBlock Text="{Binding Projection.AnnualFederalWithholding, StringFormat='Annual Federal Tax: {0:C}'}" />
          <TextBlock Text="{Binding Projection.AnnualSocialSecurity, StringFormat='Annual Social Security: {0:C}'}" />
          <TextBlock Text="{Binding Projection.AnnualMedicare, StringFormat='Annual Medicare: {0:C}'}" />
          <TextBlock Text="{Binding Projection.AnnualStateWithholding, StringFormat='Annual State Tax: {0:C}'}" />
          <TextBlock Text="{Binding Projection.AnnualNetPay, StringFormat='Annual Net Pay: {0:C}'}" FontWeight="Bold"/>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
