<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PaycheckCalc.Avalonia.Views"
        x:Class="PaycheckCalc.Avalonia.MainWindow"
        Title="Paycheck Calculator"
        Width="1200" Height="800">
  <Grid ColumnDefinitions="200,*">
    <Border Grid.Column="0" Background="#2B2B2B">
      <ListBox x:Name="NavList" Background="Transparent" SelectionChanged="NavList_SelectionChanged">
        <ListBoxItem Content="📊 Calculator" Foreground="White" />
        <ListBoxItem Content="💼 Self-Employment" Foreground="White" />
        <ListBoxItem Content="📂 Saved Paychecks" Foreground="White" />
        <ListBoxItem Content="📅 Annual Tax" Foreground="White" />
        <ListBoxItem Content="📈 Annual Projection" Foreground="White" />
        <ListBoxItem Content="⚖️ Compare" Foreground="White" />
        <ListBoxItem Content="🎓 Credits" Foreground="White" />
        <ListBoxItem Content="💹 Jobs &amp; YTD" Foreground="White" />
        <ListBoxItem Content="💰 Other Income" Foreground="White" />
        <ListBoxItem Content="📋 Quarterly Estimates" Foreground="White" />
        <ListBoxItem Content="🔮 What-If" Foreground="White" />
      </ListBox>
    </Border>
    <ScrollViewer Grid.Column="1">
      <ContentControl x:Name="ContentArea" />
    </ScrollViewer>
  </Grid>
</Window>
